# TinyFish Web Agent API key (required for live scraping)
# Get yours at https://tinyfish.ai
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# Optional: OpenRouter key for LLM-based query parsing
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# HTTP timeout for the TinyFish agent (seconds)
SCRAPER_TIMEOUT=120
